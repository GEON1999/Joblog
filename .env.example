# Supabase 프로젝트 설정 (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 오너(무제한) 등급 이메일. 쉼표로 여러 개 지정 가능. (ADR 0010)
# 오픈 서비스라 로그인 자체는 누구나 가능하고, 이 목록은 스토리지 쿼터 등 사용 상한을 면제받는 계정이다.
AUTH_ALLOWED_EMAILS=you@example.com

# DB 직접 연결 (Supabase → Connect → Transaction pooler 연결 문자열)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# ICS 캘린더 피드용 HMAC 비밀 (임의의 긴 문자열). 유저별 토큰 = HMAC(이 값, userId). /api/ics?uid=...&token=... 에 쓰인다
ICS_FEED_SECRET=change-me-to-a-long-random-string

# 파일 업로드용 service role 키 (Settings → API → service_role). 서버 전용, 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile 캡차 — 공개 가입 봇 방어 (ADR 0010). Supabase Auth → Attack Protection 에서 CAPTCHA 활성화 후 사용
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
